{
  "name": "payload-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "docker:dev": "docker compose up -d web --build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:restart": "docker compose restart",
    "docker:clean": "docker system prune -a",
    "db:backup": "mkdir -p backups && docker compose exec -T web cat /app/data/database.db > ./backups/database-$(date +%Y%m%d-%H%M%S).db && echo '✓ 备份已保存到 ./backups/database-*.db'",
    "db:restore": "bash scripts/restore.sh db",
    "backup:list": "bash scripts/restore.sh list",
    "backup:media": "bash scripts/restore.sh media",
    "backup:full": "bash scripts/restore.sh full",
    "backup:oss": "bash scripts/restore.sh oss",
    "backup:oss:list": "bash scripts/restore.sh oss-list"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@payloadcms/db-sqlite": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "payload": "^3.85.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "sass": "^1.89.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
