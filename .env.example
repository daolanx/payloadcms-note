# =============================================================================
# App（填入 .env.local，部署到服务器）
# =============================================================================

PAYLOAD_SECRET=your-production-secret-here
NEXT_PUBLIC_SITE_URL=https://your-domain.com
REVALIDATION_SECRET=your-revalidation-secret

# =============================================================================
# Database
# =============================================================================

DATABASE_URI=postgres://user:password@host:5432/payload

# =============================================================================
# Storage (Alibaba Cloud OSS)
# =============================================================================

OSS_ENDPOINT=https://your-oss-endpoint.aliyuncs.com
OSS_BUCKET=your-media-bucket
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Public vars (used by image loader on client side)
NEXT_PUBLIC_OSS_ENDPOINT=https://your-oss-endpoint.aliyuncs.com
NEXT_PUBLIC_OSS_BUCKET=your-media-bucket

# =============================================================================
# CI/CD（填入 GitHub repo variables / secrets，不放入 .env.local）
# =============================================================================

# GitHub Variables:
# ACR_REGISTRY=your-acr-registry.aliyuncs.com
# ACR_NAMESPACE=your-acr-namespace
# ACR_USERNAME=your-acr-username
# IMAGE_NAME=payload-notes

# GitHub Secrets:
# ACR_PASSWORD=your-acr-password
