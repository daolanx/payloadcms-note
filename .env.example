# Payload CMS
PAYLOAD_SECRET=your-production-secret-here
NEXT_PUBLIC_SITE_URL=https://your-domain.com
REVALIDATION_SECRET=your-revalidation-secret

# PostgreSQL
DATABASE_URI=postgres://user:password@host:5432/payload

# Alibaba Cloud OSS (media storage)
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-media-bucket
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Public OSS vars (used by image loader on client side)
NEXT_PUBLIC_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
NEXT_PUBLIC_OSS_BUCKET=your-media-bucket

# Deploy (ACR / ECS) — used by scripts/ and CI
ACR_REGISTRY=crpi-l5xg3bxsmy58r36i.cn-hangzhou.personal.cr.aliyuncs.com
ACR_NAMESPACE=daolanx
ACR_USERNAME=daolanx
IMAGE_NAME=payload-notes
ECS_HOST=your-ecs-ip
ECS_USERNAME=root
DEPLOY_PATH=/opt/blog
